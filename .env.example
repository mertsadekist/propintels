# ─────────────────────────────────────────
# App
# ─────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─────────────────────────────────────────
# Database (MySQL via PlanetScale or local)
# ─────────────────────────────────────────
DATABASE_URL="mysql://root:password@localhost:3306/ist_valuation"

# ─────────────────────────────────────────
# Authentication (NextAuth.js)
# ─────────────────────────────────────────
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-secret-here-at-least-32-chars

# ─────────────────────────────────────────
# Redis (for BullMQ job queue)
# ─────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─────────────────────────────────────────
# S3-compatible storage (Cloudflare R2 or AWS)
# ─────────────────────────────────────────
S3_BUCKET=ist-reports
S3_REGION=auto
S3_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
S3_ACCESS_KEY_ID=your-access-key
S3_SECRET_ACCESS_KEY=your-secret-key

# ─────────────────────────────────────────
# Email / SMTP
# Option A — Resend (recommended)
#   Set EMAIL_API_KEY to your Resend API key.
#   The mailer will use smtp.resend.com:465 automatically.
# Option B — Generic SMTP
#   Leave EMAIL_API_KEY empty and set SMTP_* vars below.
# ─────────────────────────────────────────
EMAIL_FROM=noreply@yourcompany.com

# Option A: Resend
EMAIL_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# Option B: Generic SMTP
SMTP_HOST=smtp.yourprovider.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-smtp-username
SMTP_PASS=your-smtp-password
